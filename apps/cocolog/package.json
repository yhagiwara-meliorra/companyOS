{
  "name": "cocolog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:types": "supabase gen types typescript --local --schema public --schema integrations --schema ai --schema analytics --schema billing --schema ops --schema audit > src/types/database.ts",
    "db:start": "supabase start",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@sentry/nextjs": "^9.15.0",
    "@slack/bolt": "^4.1.0",
    "@slack/oauth": "^3.0.0",
    "@slack/web-api": "^7.8.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/postcss": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "^15.3.3",
    "postcss": "^8.5.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.2.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.20.0",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
