{
  "crons": [
    {
      "path": "/api/cron/daily-rollup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/weekly-rollup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/analyze-pending",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/retry-pending-events",
      "schedule": "*/30 * * * *"
    }
  ]
}
